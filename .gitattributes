# Auto detect text files and normalize line endings to LF
* text=auto

# TypeScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary

# Git
.gitattributes text
.gitignore text
