{
  "name": "filebound-notes",
  "displayName": "Filebound Notes",
  "description": "Per-file notes in a VS Code sidebar panel",
  "version": "0.0.1",
  "license": "MIT",
  "author": "mgrosshauser",
  "publisher": "mgrosshauser",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mgrosshauser/filebound-notes-vscode"
  },
  "engines": {
    "vscode": "^1.74.0",
    "node": ">=18.0.0"
  },
  "categories": ["Other"],
  "keywords": [
    "notes",
    "annotations",
    "file notes",
    "sidebar",
    "productivity"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "filebound-notes.clearAll",
        "title": "Clear All Notes",
        "category": "File Notes"
      },
      {
        "command": "filebound-notes.insertRefFromEditor",
        "title": "Insert Line Reference to File Notes",
        "category": "File Notes"
      },
      {
        "command": "filebound-notes.searchNotes",
        "title": "Search Notes",
        "category": "File Notes"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "filebound-notes.insertRefFromEditor",
          "group": "filebound-notes@1",
          "when": "editorTextFocus"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "filebound-notes.notesView",
          "name": "File Notes",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
