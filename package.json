{
  "name": "filebound-notes",
  "displayName": "File Notes",
  "description": "Per-file notes in a VS Code sidebar panel",
  "version": "0.0.1",
  "license": "MIT",
  "author": "mgrosshauser",
  "publisher": "mgrosshauser",
  "repository": {
    "type": "git",
    "url": "https://github.com/mgrosshauser/filebound-notes-vscode"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "filebound-notes.clearAll",
        "title": "File Notes: Clear All Notes",
        "category": "File Notes"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "filebound-notes.notesView",
          "name": "File Notes",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
